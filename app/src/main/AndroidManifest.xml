<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Timer and notification permissions -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- AdMob / UMP: network access for loading ads and consent form -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!--
        Android 13+ Advertising ID permission.
        Required when using AdMob on API 33+. Users who opt out of personalised ads
        will receive a zeroed-out ID; the SDK handles this automatically.
    -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" />

    <!-- Android Auto: mark automotive as optional so the app also runs on phones -->
    <uses-feature
        android:name="android.hardware.type.automotive"
        android:required="false" />

    <application
        android:name=".ParkAlertApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ParkTimer">

        <!--
            AdMob Application ID.
            TODO: Replace the test App ID below with your real AdMob App ID
                  before publishing to the Play Store.
            Test App ID: ca-app-pub-3940256099942544~3347511913
        -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="@string/admob_app_id" />

        <!-- Phone UI -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.ParkTimer.Splash"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".TimerActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".SettingsActivity"
            android:exported="false" />

        <activity
            android:name=".PrivacyPolicyActivity"
            android:exported="false" />

        <!-- Background timer service -->
        <service
            android:name=".TimerService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Android Auto / Car App Service -->
        <service
            android:name=".automotive.ParkAlertCarAppService"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="androidx.car.app.CarAppService" />
                <category android:name="androidx.car.app.category.IOT" />
            </intent-filter>
            <meta-data
                android:name="androidx.car.app.minCarApiLevel"
                android:value="1" />
        </service>

        <!-- Required for Android Auto app descriptor -->
        <meta-data
            android:name="com.google.android.gms.car.application"
            android:resource="@xml/automotive_app_desc" />

    </application>

</manifest>

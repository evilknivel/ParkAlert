<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/green_light">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/green_primary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        android:elevation="4dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- ── Privacy section ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_section_privacy"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/green_dark"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnConsent"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:text="@string/settings_consent"
                android:textSize="15sp"
                android:textColor="@color/green_dark" />

            <Button
                android:id="@+id/btnPrivacyPolicy"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="32dp"
                android:text="@string/settings_privacy_policy"
                android:textSize="15sp"
                android:textColor="@color/green_dark" />

            <!-- ── App info section ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_section_app"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/green_dark"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvAppVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="#555555"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnLicenses"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/settings_licenses"
                android:textSize="15sp"
                android:textColor="@color/green_dark" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
